#pragma once

// Wi-Fi credentials + uplink host for the state-push background task.
//
// Setup: copy this file to secrets.h (in the same directory) and fill
// in real values. secrets.h is gitignored so your credentials never
// reach the repo.
//
//   cp arduino-source/main/secrets.h.example arduino-source/main/secrets.h
//
// secrets.h is included from main.ino; the sketch won't build without it.

#define WIFI_SSID     "your-ssid"
#define WIFI_PASSWORD "your-password"

// Override only if you're pointing at a non-production Worker. Strip
// the protocol — StatePusher prepends "https://".
#define EMBER_API_HOST "embersensor.com"
